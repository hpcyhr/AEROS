# =============================================================================
# AEROS .gitignore  (complete corrected version)
# =============================================================================
# Strategy: keep all source code (.py / .sh / .tex / .md), ignore data
# products (.json / .npz / .pth), build artifacts (.log / .aux / .pdf),
# and environment crap (.pyc / __pycache__ / .vscode).

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
.installed.cfg
develop-eggs/
eggs/
.eggs/
parts/
sdist/
var/
wheels/
share/python-wheels/
MANIFEST

# Virtual environments
venv/
env/
ENV/
.venv/
.env/

# pip
pip-log.txt
pip-delete-this-directory.txt

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# pytest / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/

# mypy / ruff / pylint
.mypy_cache/
.dmypy.json
.ruff_cache/
.pylintrc.local

# -----------------------------------------------------------------------------
# PyTorch / ML artifacts
# -----------------------------------------------------------------------------
# Trained checkpoints — too big for git
*.pth
*.pt
*.ckpt
*.safetensors
*.bin
checkpoints/
checkpoints_*/
ckpt/
ckpts/

# Numpy serialized data
*.npz
*.npy

# HDF5 / pickle
*.h5
*.hdf5
*.pkl
*.pickle

# ONNX / TF artifacts
*.onnx
*.pb

# TensorBoard
runs/
tb_logs/
tensorboard/

# Weights & Biases
wandb/

# -----------------------------------------------------------------------------
# AEROS experiment artifacts (regenerable from V100 runs)
# -----------------------------------------------------------------------------
# JSON experiment outputs
p9_*.json
p7_*.json
p5_*.json
*_results.json
*_aggregate*.json
*_smoke.json
*_full.json
*_full16.json
*_medium.json

# NPZ sweep / fit results
p7_*_results.npz
p5_*_results.npz
phase*.npz
*_sweep.npz
*_fit.npz

# Density / event-camera intermediate files
density_*.npz
m1_*.npz
phaseA_*.npz

# Latex sources auto-generated by experiments (e.g. p9_5_certificate.tex)
p9_*.tex

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
nohup.out
*.out

# -----------------------------------------------------------------------------
# Datasets — never commit raw data
# -----------------------------------------------------------------------------
datasets/
data/
data_*/
download/
extract/
*.aedat
*.aedat3
*.aedat4
cifar-10-batches-py/
cifar-10-python.tar.gz
DVS128Gesture/
N-MNIST/
NCALTECH101/
events_np/
frames_np/
frames_number_*/

# Compressed dataset archives
*.7z
*.tar
*.tar.gz
*.tgz
*.zip
*.rar

# Specific big files
Prophesee_*
prophesee_*

# -----------------------------------------------------------------------------
# LaTeX paper artifacts
# -----------------------------------------------------------------------------
# Compilation byproducts
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.synctex.gz
*.toc
*.lof
*.lot
*.idx
*.ind
*.ilg
*.glg
*.glo
*.gls
*.acn
*.acr
*.alg
*.nav
*.snm
*.vrb
*.dvi
*.out

# Build dirs
.texpadtmp/
_minted-*/

# Compiled PDFs — ignore by default, whitelist paper PDFs explicitly
*.pdf
!aeros_v9_phase1_*.pdf
!catfuse_*.pdf

# Editor swap files
*.tex.bak
*.tex~

# -----------------------------------------------------------------------------
# Editor / IDE
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
.project
.settings/

# -----------------------------------------------------------------------------
# Git scratch
# -----------------------------------------------------------------------------
*.orig
*.rej

# -----------------------------------------------------------------------------
# Project-specific transient files
# -----------------------------------------------------------------------------
# Local config / secrets
.env.local
secrets.json
config.local.*

# Profiling output
*.prof
*.lprof
nsys-rep
nsight-cuprof-report-*

# Scratch / draft
scratch/
tmp/
temp/
draft/
notes_local.md
TODO.local.md

# Anything explicitly marked as private / local
*.local
*.private